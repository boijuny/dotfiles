"$schema" = 'https://starship.rs/config-schema.json'

add_newline = true
command_timeout = 1000

# Standard multi-line layout for a clean typing area
format = """
$directory\
$git_branch\
$git_status\
$conda\
$python
$character"""

[character]
[directory]
truncation_length = 2
[git_branch]
[git_status]
[python]
[conda]
ignore_base = true
