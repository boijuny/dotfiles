# Base .zshrc that loads modular topics
# Use the physical path of this script to find the dotfiles root
DOTFILES_DIR="$(dirname "$(dirname "$(dirname "$(readlink -f "${(%):-%x}")")")")"

# Load all *.zsh files in topics/ subfolders
# We use a simple loop for maximum compatibility and speed
for topic_file in "$DOTFILES_DIR"/topics/**/*.zsh; do
    [ -f "$topic_file" ] && source "$topic_file"
done

unset topic_file
